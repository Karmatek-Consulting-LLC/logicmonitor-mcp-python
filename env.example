# LogicMonitor account subdomain: the "acme" in https://acme.logicmonitor.com
LM_COMPANY=your-account

# LogicMonitor API Bearer token. In Roundhouse, mark this env var as "secret".
LM_BEARER_TOKEN=

# Portal domain suffix (optional, default logicmonitor.com).
# For LM for Government, set your gov domain, e.g. logicmonitorgov.com
# LM_DOMAIN=logicmonitorgov.com

# Full portal base URL override (optional). Wins over LM_COMPANY/LM_DOMAIN.
# Use for gov / custom / on-prem hosts, e.g. https://acme.logicmonitorgov.com
# LM_BASE_URL=

# Per-request timeout in seconds (optional, default 30).
LM_API_TIMEOUT=30
