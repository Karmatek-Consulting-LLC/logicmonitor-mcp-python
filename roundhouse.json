{
  "env": [
    {
      "name": "LM_COMPANY",
      "secret": false,
      "required": true,
      "description": "LogicMonitor account subdomain (the 'acme' in acme.logicmonitor.com)"
    },
    {
      "name": "LM_BEARER_TOKEN",
      "secret": true,
      "required": true,
      "description": "LogicMonitor API Bearer token"
    },
    {
      "name": "LM_DOMAIN",
      "secret": false,
      "required": false,
      "description": "Portal domain suffix (default logicmonitor.com). For LM for Government, e.g. logicmonitorgov.com"
    },
    {
      "name": "LM_BASE_URL",
      "secret": false,
      "required": false,
      "description": "Full portal base URL override, e.g. https://acme.logicmonitorgov.com. Wins over LM_COMPANY/LM_DOMAIN"
    },
    {
      "name": "LM_API_TIMEOUT",
      "secret": false,
      "required": false,
      "description": "Per-request timeout in seconds (default 30)"
    }
  ],
  "pip_packages": ["httpx"],
  "apt_packages": []
}
